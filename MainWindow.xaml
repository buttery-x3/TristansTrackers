<Window
    x:Class="TristansTrackers.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="TristansTrackers"
    Width="100"
    Height="20"
    AllowsTransparency="True"
    Background="#19FFFFFF"
    Loaded="MainWindow_Loaded"
    MouseDown="Window_MouseDown"
    MouseEnter="RootGrid_MouseEnter"
    MouseLeave="RootGrid_MouseLeave"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStyle="None">

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Exit" Click="ExitMenuItem_Click" />
        </ContextMenu>
    </Window.ContextMenu>

    <Grid x:Name="WindowGrid">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="AlarmRow" Height="0" />
            <RowDefinition x:Name="TrackerRow" Height="*" />
        </Grid.RowDefinitions>

        <Border
            x:Name="AlarmBorder"
            Grid.Row="0"
            Padding="3"
            Background="#00000000"
            BorderBrush="#FFFF0101"
            BorderThickness="0"
            CornerRadius="0"
            Visibility="Collapsed">

            <Grid x:Name="AlarmGrid">
                <Rectangle
                    x:Name="AlarmFillBar"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch"
                    Fill="#BF000000" />

                <Border
                    x:Name="AlarmPulseOverlay"
                    BorderBrush="#F2FFFFFF"
                    BorderThickness="1.5"
                    IsHitTestVisible="False"
                    Opacity="0">
                    <Border.Effect>
                        <DropShadowEffect
                            x:Name="AlarmGlow"
                            BlurRadius="0"
                            Color="White"
                            Opacity="0"
                            ShadowDepth="0" />
                    </Border.Effect>
                </Border>

                <TextBlock
                    x:Name="AlarmRemainingText"
                    Margin="0,0,3,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    FontSize="10"
                    Foreground="White"
                    IsHitTestVisible="False"
                    Text="5 min"
                    Visibility="Collapsed" />
            </Grid>
        </Border>

        <Border
            x:Name="MainBorder"
            Grid.Row="1"
            Padding="3"
            Background="#00000000"
            BorderBrush="#FFFF0101"
            BorderThickness="0"
            CornerRadius="0">

            <Grid x:Name="RootGrid">
                <Rectangle
                    x:Name="FillBar"
                    Width="0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch"
                    Fill="#BF000000" />

                <Border
                    x:Name="CompletionPulseOverlay"
                    BorderBrush="#F2FFFFFF"
                    BorderThickness="1.5"
                    IsHitTestVisible="False"
                    Opacity="0">
                    <Border.Effect>
                        <DropShadowEffect
                            x:Name="CompletionGlow"
                            BlurRadius="0"
                            Color="White"
                            Opacity="0"
                            ShadowDepth="0" />
                    </Border.Effect>
                </Border>

                <Button
                    x:Name="AlarmButton"
                    Width="14"
                    Height="14"
                    Margin="0"
                    Padding="1"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="#19000000"
                    BorderBrush="Red"
                    BorderThickness="0"
                    Click="AlarmButton_Click"
                    Foreground="White"
                    ToolTip="Set alarm"
                    Visibility="Collapsed">

                    <Viewbox Width="11" Height="11">
                        <Canvas Width="16" Height="16">
                            <Ellipse
                                Canvas.Left="3"
                                Canvas.Top="3"
                                Width="10"
                                Height="10"
                                Stroke="White"
                                StrokeThickness="1.5" />
                            <Line
                                X1="8"
                                Y1="5.5"
                                X2="8"
                                Y2="8.5"
                                Stroke="White"
                                StrokeEndLineCap="Round"
                                StrokeThickness="1.5" />
                            <Line
                                X1="8"
                                Y1="8.5"
                                X2="10.5"
                                Y2="10"
                                Stroke="White"
                                StrokeEndLineCap="Round"
                                StrokeThickness="1.5" />
                            <Line
                                X1="3.5"
                                Y1="3"
                                X2="5.5"
                                Y2="1.5"
                                Stroke="White"
                                StrokeStartLineCap="Round"
                                StrokeEndLineCap="Round"
                                StrokeThickness="1.5" />
                            <Line
                                X1="10.5"
                                Y1="1.5"
                                X2="12.5"
                                Y2="3"
                                Stroke="White"
                                StrokeStartLineCap="Round"
                                StrokeEndLineCap="Round"
                                StrokeThickness="1.5" />
                            <Line
                                X1="5"
                                Y1="12.5"
                                X2="3.5"
                                Y2="14.5"
                                Stroke="White"
                                StrokeStartLineCap="Round"
                                StrokeEndLineCap="Round"
                                StrokeThickness="1.5" />
                            <Line
                                X1="11"
                                Y1="12.5"
                                X2="12.5"
                                Y2="14.5"
                                Stroke="White"
                                StrokeStartLineCap="Round"
                                StrokeEndLineCap="Round"
                                StrokeThickness="1.5" />
                        </Canvas>
                    </Viewbox>
                </Button>

                <Button
                    x:Name="LockButton"
                    Width="14"
                    Height="14"
                    Margin="0"
                    Padding="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="#19000000"
                    BorderBrush="Red"
                    BorderThickness="0"
                    Click="LockButton_Click"
                    Foreground="White"
                    Visibility="Visible">

                    <TextBlock
                        x:Name="LockIcon"
                        FontSize="10"
                        Text="🔓" />
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
