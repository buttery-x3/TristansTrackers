<Window
    x:Class="TristansTrackers.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="LifePanel"
    Width="300"
    Height="100"
    AllowsTransparency="True"
    Background="Transparent"
    MouseDown="Window_MouseDown"
    Topmost="True"
    WindowStyle="None">
    <Window.Resources>

        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Border Padding="4" Background="Transparent">
                <Path
                    HorizontalAlignment="Right"
                    Data="M 0 0 L 10 10 L 20 0"
                    RenderTransformOrigin="0.5,0.5"
                    Stroke="White"
                    StrokeThickness="2" />
            </Border>
        </ControlTemplate>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!--  TOGGLE BUTTON (just the arrow)  -->
                            <ToggleButton
                                x:Name="ToggleButton"
                                Grid.Column="0"
                                HorizontalAlignment="Right"
                                Background="Transparent"
                                BorderThickness="0"
                                ClickMode="Press"
                                Focusable="False"
                                IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <Path
                                    Data="M 0 0 L 10 10 L 20 0"
                                    RenderTransformOrigin="0.5,0.5"
                                    Stroke="White"
                                    StrokeThickness="2" />
                            </ToggleButton>

                            <!--  SELECTED TEXT  -->
                            <ContentPresenter
                                x:Name="ContentSite"
                                Margin="28,0,4,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding SelectionBoxItem}"
                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                RecognizesAccessKey="True" />

                            <!--  DROPDOWN POPUP  -->
                            <Popup
                                x:Name="Popup"
                                AllowsTransparency="True"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                Placement="Bottom"
                                PopupAnimation="Fade">

                                <Border
                                    Padding="4"
                                    Background="#222"
                                    CornerRadius="6">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>

                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>
    <Border
        Name="MainBorder"
        Padding="10"
        Background="#AA1E1E1E"
        BorderBrush="WhiteSmoke"
        BorderThickness=".5"
        CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Expand/Collapse Icon  -->
            <Button
                x:Name="ExpandButton"
                Grid.Row="0"
                Width="24"
                Height="24"
                Margin="0,0,5,0"
                HorizontalAlignment="Right"
                Background="Transparent"
                BorderThickness="0"
                Click="ExpandButton_Click">

                <Path
                    x:Name="ExpandIcon"
                    Data="M 0 0 L 10 10 L 20 0"
                    RenderTransformOrigin="0.5,0.5"
                    Stroke="White"
                    StrokeThickness="2">
                    <Path.RenderTransform>
                        <RotateTransform Angle="0" />
                    </Path.RenderTransform>
                </Path>
            </Button>

            <!--  Main content  -->
            <StackPanel
                Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal">

                <!--  Activity Selector  -->

                <!--  Timer Text  -->
                <!--  Timer Text  -->
                <ComboBox
                    x:Name="ActivitySelector"
                    Width="140"
                    Background="{x:Null}"
                    BorderBrush="#00ACACAC"
                    Foreground="White"
                    SelectedIndex="0"
                    SelectionChanged="ActivitySelector_SelectionChanged">
                    <ComboBoxItem Content="Working" />
                    <ComboBoxItem Content="Resting" />
                    <ComboBoxItem Content="Stretching" />
                    <ComboBoxItem Content="Watching" />
                    <ComboBoxItem Content="Playing" />
                    <ComboBoxItem Content="Chatting" />
                    <ComboBoxItem Content="Browsing" />
                </ComboBox>
                <TextBlock
                    x:Name="TimerText"
                    FontSize="18"
                    Foreground="White"
                    Text="00:00" />

            </StackPanel>

        </Grid>
    </Border>
</Window>
