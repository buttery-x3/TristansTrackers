<Window
    x:Class="TristansTrackers.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="TristansTrackers"
    Width="100"
    Height="20"
    AllowsTransparency="True"
    Background="#19FFFFFF"
    Loaded="MainWindow_Loaded"
    MouseDown="Window_MouseDown"
    MouseEnter="RootGrid_MouseEnter"
    MouseLeave="RootGrid_MouseLeave"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStyle="None">

    <Border
        Name="MainBorder"
        Padding="3"
        Background="#00000000"
        BorderBrush="#FFFF0101"
        BorderThickness="0"
        CornerRadius="0">

        <Grid x:Name="RootGrid">
            <Rectangle
                x:Name="FillBar"
                Width="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Stretch"
                Fill="#BF000000" />

            <Border
                x:Name="CompletionPulseOverlay"
                BorderBrush="#F2FFFFFF"
                BorderThickness="1.5"
                IsHitTestVisible="False"
                Opacity="0">
                <Border.Effect>
                    <DropShadowEffect
                        x:Name="CompletionGlow"
                        BlurRadius="0"
                        Color="White"
                        Opacity="0"
                        ShadowDepth="0" />
                </Border.Effect>
            </Border>

            <Button
                x:Name="LockButton"
                Width="14"
                Height="14"
                Margin="0"
                Padding="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="#19000000"
                BorderBrush="Red"
                BorderThickness="0"
                Click="LockButton_Click"
                Foreground="White"
                Visibility="Visible">

                <TextBlock
                    x:Name="LockIcon"
                    FontSize="10"
                    Text="🔓" />
            </Button>
        </Grid>
    </Border>
</Window>
